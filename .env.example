# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="COLOCAR_GEMINI_API_KEY_AQUI"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:5173"

# GLPI Configuration
VITE_GLPI_URL=http://exemplo.local/apirest.php
GLPI_APP_TOKEN=COLOCAR_GLPI_APP_TOKEN_AQUI
GLPI_USER=COLOCAR_GLPI_USER_AQUI
GLPI_PASSWORD=COLOCAR_GLPI_PASSWORD_AQUI

# Zabbix Configuration
VITE_ZABBIX_URL=http://exemplo.local/api_jsonrpc.php
VITE_ZABBIX_TOKEN=COLOCAR_ZABBIX_TOKEN_AQUI
ZABBIX_USER=COLOCAR_ZABBIX_USER_AQUI
ZABBIX_PASSWORD=COLOCAR_ZABBIX_PASSWORD_AQUI
# NODE_TLS_REJECT_UNAUTHORIZED=0 # Use only if Zabbix has self-signed SSL

# Telegram Bot Configuration (For Notifications)
TELEGRAM_BOT_TOKEN=COLOCAR_TELEGRAM_BOT_TOKEN_AQUI
TELEGRAM_CHAT_ID=COLOCAR_TELEGRAM_CHAT_ID_AQUI
